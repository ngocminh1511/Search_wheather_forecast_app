# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# ── Paths (optional — auto-detected from repo root if not set) ────────────────
# NOAA_BASE_DIR=/absolute/path/to/Search_wheather_forecast_app
# NOAA_DB_DIR=/absolute/path/to/database

# ── Tile generation ───────────────────────────────────────────────────────────
TILE_WORKERS=8
TILE_ZOOM_EAGER_MAX=8
TILE_ZOOM_LAZY_MAX=10
TILE_CACHE_MB=2048

# ── Download ──────────────────────────────────────────────────────────────────
NOAA_RPM_LIMIT=100
DOWNLOAD_RETRIES=5

# ── Retention ─────────────────────────────────────────────────────────────────
KEEP_CYCLES=4
CLOUD_KEEP_CYCLES=4

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=false
CHECK_INTERVAL_MINUTES=30

# ── Bunny.net Storage (CDN sync) ──────────────────────────────────────────────
# Master switch: 0 = noop (local only), 1 = sync tiles to Bunny CDN
BUNNY_ENABLED=1
# Bunny Storage Zone name (required when BUNNY_ENABLED=1)
BUNNY_STORAGE_ZONE=weather-tiles
# Bunny Storage Zone API key/password (required when BUNNY_ENABLED=1)
BUNNY_API_KEY=e14cdf80-5cdf-4122-9b5b26d3a747-35d8-4fd0
# Region: empty = global default; or "ny", "la", "sg", "syd", "uk", "de", "br", "jh", "se"
BUNNY_REGION=
# Path prefix on Bunny (default: "tiles")
BUNNY_PATH_PREFIX=tiles
# CDN pull-zone URL for client-side reading (e.g. https://noaa.b-cdn.net)
BUNNY_PULL_ZONE_URL=https://weather-tiles-cdn.b-cdn.net
# Concurrent uploads per push_frame call (16 is a good balance)
BUNNY_MAX_PARALLEL=16
# Retries on transient errors (429, 5xx, timeouts)
BUNNY_RETRY_ATTEMPTS=4
# HTTP timeout in seconds (lower = faster fail-fast on Bunny disconnect)
BUNNY_TIMEOUT_S=30
# 1 = raise + abort job on first upload failure; 0 = log + continue
BUNNY_FAIL_FAST=0
# 1 = delete previous Bunny run immediately after pointer switch (recommended)
BUNNY_DELETE_PREV_AFTER_SWITCH=1

# ── Telegram bot reporting ────────────────────────────────────────────────────
# Master switch: 0 = no Telegram, 1 = send alerts
TELEGRAM_ENABLED=1
# From @BotFather: /newbot → token like 1234567890:ABC...
TELEGRAM_BOT_TOKEN=8469453727:AAETXx8im8V68rvqXKDcY8jhbDSUOlDWfmo
# Chat ID: your user ID (positive int) or group ID (negative int starting with -100)
TELEGRAM_CHAT_ID=1773013279
# Verbosity: 0=critical+daily only, 1=+per-cycle, 2=+per-map (default)
TELEGRAM_VERBOSITY=2

# ── Bunny Statistics API (account-level, for daily user analytics) ────────────
# Account API Key (NOT storage zone password!): https://dash.bunny.net/account/settings
BUNNY_ACCOUNT_API_KEY=de902e29-694a-457e-9628-718b60b7a55da8e071c5-dfa8-4c7c-988a-8481d0671d74
# Numeric IDs from Bunny dashboard URLs
BUNNY_PULL_ZONE_ID=5821095
BUNNY_STORAGE_ZONE_ID=1504960

# ── Reporting schedule ────────────────────────────────────────────────────────
# Daily report time (UTC). 00:30 = after cycle 18z completes
DAILY_REPORT_UTC_HOUR=0
DAILY_REPORT_UTC_MINUTE=30
# Bunny analytics polling interval (minutes)
BUNNY_ANALYTICS_POLL_MIN=60
