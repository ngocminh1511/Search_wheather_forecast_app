# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# ── Paths (optional — auto-detected from repo root if not set) ────────────────
# NOAA_BASE_DIR=/absolute/path/to/Search_wheather_forecast_app

# ── Tile generation ───────────────────────────────────────────────────────────
TILE_WORKERS=8
TILE_ZOOM_EAGER_MAX=5
TILE_ZOOM_LAZY_MAX=10
TILE_CACHE_MB=2048

# ── Download ──────────────────────────────────────────────────────────────────
NOAA_RPM_LIMIT=100
DOWNLOAD_RETRIES=5

# ── Retention ─────────────────────────────────────────────────────────────────
KEEP_CYCLES=4
CLOUD_KEEP_CYCLES=4

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
CHECK_INTERVAL_MINUTES=30
